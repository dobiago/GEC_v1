{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/projects",
      "destination": "/operations",
      "statusCode": 308,
      "regex": "^(?!/_next)/projects(?:/)?$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/about/team/[person]",
      "regex": "^/about/team/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPperson": "nxtPperson"
      },
      "namedRegex": "^/about/team/(?<nxtPperson>[^/]+?)(?:/)?$"
    },
    {
      "page": "/operations/offshore/[asset]",
      "regex": "^/operations/offshore/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPasset": "nxtPasset"
      },
      "namedRegex": "^/operations/offshore/(?<nxtPasset>[^/]+?)(?:/)?$"
    },
    {
      "page": "/operations/onshore/[asset]",
      "regex": "^/operations/onshore/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPasset": "nxtPasset"
      },
      "namedRegex": "^/operations/onshore/(?<nxtPasset>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
