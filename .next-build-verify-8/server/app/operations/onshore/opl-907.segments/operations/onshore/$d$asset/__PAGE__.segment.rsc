0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"className":"w-full pt-28 text-slate-900","children":["$","section",null,{"className":"grid w-full gap-10 px-6 pb-20 md:px-12 lg:min-h-[calc(100vh-8rem)] lg:grid-cols-[1.1fr_0.9fr] lg:items-start","children":[["$","div",null,{"className":"space-y-8","children":[["$","div",null,{"className":"space-y-3","children":[["$","$L2",null,{}],["$","h1",null,{"className":"text-4xl font-semibold tracking-[-0.05em] text-slate-950 sm:text-5xl","children":"OPL 907"}]]}],["$","div",null,{"className":"space-y-5 rounded-sm border border-slate-200 bg-[#EDE9D0]/80 p-8 text-base leading-8 text-slate-600 shadow-[0_30px_80px_rgba(58,0,30,0.08)]","children":[["$","p","OPL 907 is located onshore Nigeria within the highly prospective Anambra Basin, which holds an estimated gas potential in the region of 10 Tcf. The license covers an area of 2,284.50 km2 and contains the Akukwa gas discovery, which has estimated in-place volumes of 400 Bcf with potential for a significant upside. AGER, an associate company of GEC, operates the asset and controls a 41% working interest.",{"children":"OPL 907 is located onshore Nigeria within the highly prospective Anambra Basin, which holds an estimated gas potential in the region of 10 Tcf. The license covers an area of 2,284.50 km2 and contains the Akukwa gas discovery, which has estimated in-place volumes of 400 Bcf with potential for a significant upside. AGER, an associate company of GEC, operates the asset and controls a 41% working interest."}],["$","p","Six wells have so far been drilled in the block, including four shallow dry wells by Shell in 1938 and 1939, and two successful wells, Akukwa-1 and Akukwa-2, drilled by Shell/BP in 1955 and 1956 respectively. The Akukwa-1 discovered gas and condensate in Cretaceous sandstones, while the Akukwa-2 appraisal well intersected approximately 150 m net gas pay and produced dry gas on test. The two wells make up the Akukwa field located within the Ugwuoba community of Enugu State.",{"children":"Six wells have so far been drilled in the block, including four shallow dry wells by Shell in 1938 and 1939, and two successful wells, Akukwa-1 and Akukwa-2, drilled by Shell/BP in 1955 and 1956 respectively. The Akukwa-1 discovered gas and condensate in Cretaceous sandstones, while the Akukwa-2 appraisal well intersected approximately 150 m net gas pay and produced dry gas on test. The two wells make up the Akukwa field located within the Ugwuoba community of Enugu State."}]]}],null]}],["$","div",null,{"className":"lg:sticky lg:top-32","children":["$","div",null,{"className":"aspect-[4/3] w-full rounded-[32px] border border-slate-200 bg-slate-100 bg-cover bg-center shadow-[0_30px_80px_rgba(58,0,30,0.08)]","style":{"backgroundImage":"url(/operations/opl_907.jpg)"}}]}]]}]}],[["$","script","script-0",{"src":"/_next/static/chunks/0~9yhc1ei_0rn.js","async":true}]],["$","$L3",null,{"children":["$","$4",null,{"name":"Next.MetadataOutlet","children":"$@5"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"vvlN-ZBIJ5vqfHzBw6C4v"}
